# syntax=docker/dockerfile:1
FROM debian:stable-slim

USER root

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    UV_SYSTEM_PYTHON=1 \
    UV_BREAK_SYSTEM_PACKAGES=1

# 1. Cài đặt hệ thống
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates procps git sudo python3 python3-pip python3-dev python3-venv \
    gcc g++ curl htop ncdu \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# 2. Lấy uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /root

# 3. Cài đặt JupyterLab 4 & Proxy
RUN uv pip install --system --no-cache \
    "jupyterlab>=4.0.0" \
    "jupyter-resource-usage>=1.0.0" \
    "jupyter-server-proxy>=4.0.0"

# 4. Cấu hình JSON (Sạch log, chuẩn IdentityProvider)
RUN mkdir -p /root/.jupyter/
RUN echo '{ \
  "ServerApp": { \
    "jpserver_extensions": { "jupyter_server_proxy": true }, \
    "log_level": "WARN", \
    "disable_check_xsrf": true, \
    "allow_origin": "*", \
    "trust_xheaders": true \
  }, \
  "IdentityProvider": { \
    "cookie_options": { "SameSite": "None", "Secure": true } \
  }, \
  "ServerProxy": { \
    "host_allowlist": ["*"] \
  } \
}' > /root/.jupyter/jupyter_server_config.json

# 5. Entrypoint Script
COPY --chmod=755 <<"EOF" /entrypoint.sh
#!/bin/bash
set -e
[ -f /root/.bashrc ] && source /root/.bashrc

if [ -n "$REMOTE_KEY" ]; then
  echo "[INFO] Dashboard Started. Use your token to access services."
  
  # Chế độ ẩn cảnh báo thừa
  export PYTHONWARNINGS="ignore"

  exec jupyter lab --ip=0.0.0.0 --port=7860 --no-browser --allow-root \
    --IdentityProvider.token="$REMOTE_KEY" \
    --ServerApp.password='' \
    --ServerApp.allow_origin_pat="https?://.*\.huggingface\.co" \
    --FileContentsManager.delete_to_trash=False \
    --ContentsManager.allow_hidden=True \
    --ResourceUseDisplay.track_cpu_percent=True \
    --ResourceUseDisplay.show_host_usage=True
else
  echo "⚠️ [ERROR] REMOTE_KEY is required!"
  exit 1
fi
EOF

EXPOSE 7860
ENTRYPOINT ["/entrypoint.sh"]
