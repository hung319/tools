FROM python:3.12-slim

# Cài đặt git và các package cần thiết
RUN apt-get update && apt-get install -y \
    git \
    && rm -rf /var/lib/apt/lists/*

# Clone branch canary
RUN git clone -b canary https://github.com/hmjz100/Z.ai2api.git /app

WORKDIR /app

# Cài dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Expose port nếu cần
EXPOSE 7860

CMD ["python", "app.py"]
