FROM python:3.11-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       git \
       build-essential \
       ca-certificates \
       libffi-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Clone source
RUN git clone https://github.com/CloudWaddie/LMArenaBridge.git /app

# Install dependencies
RUN pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir python-multipart

# Hai biến ARG để truyền auth_token & password
ARG AUTH_TOKEN="YOUR_AUTH_TOKEN"
ARG PASSWORD="admin"

# Tạo file config.json
RUN printf '{\n  "auth_token": "%s",\n  "password": "%s"\n}\n' "${AUTH_TOKEN}" "${PASSWORD}" > /app/config.json

EXPOSE 8000

CMD ["python", "src/main.py"]
