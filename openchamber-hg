FROM debian:stable-slim

# 1. Khai báo môi trường (Đã đổi tên và xóa HOST)
ENV PATH="/usr/local/bin:/usr/bin:${PATH}" \
    APP_PORT=8080 \
    NODE_ENV=production

WORKDIR /root

ARG DEBIAN_FRONTEND=noninteractive

# 2. Cài đặt hệ thống
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl git ssh build-essential tini procps unzip psmisc socat \
        nodejs npm \
    && curl -LsSf https://astral.sh/uv/install.sh | sh \
    && mv /root/.local/bin/uv /root/.local/bin/uvx /usr/local/bin/ \
    && uv python install 3.12 \
    && npm install -g opencode-ai@latest @openchamber/web@latest \
    && npm cache clean --force \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 3. Cấu hình wrapper script cho opencode
RUN mv /usr/local/bin/opencode /usr/local/bin/opencode-original \
    && echo '#!/bin/bash\nrm -rf /root/.cache/opencode/package.json 2>/dev/null || true\nexec /usr/local/bin/opencode-original "$@"' > /usr/local/bin/opencode \
    && chmod +x /usr/local/bin/opencode

# 4. Entrypoint: Chạy background hoàn toàn
RUN cat <<'EOF' > /usr/local/bin/entrypoint
#!/bin/bash

# Dọn dẹp sơ bộ
openchamber stop || true
fuser -k 8081/tcp || true

# Khởi chạy OpenChamber ở cổng nội bộ 8081 (Background)
# Không dùng --foreground để app tự quản lý chu trình sống/update của nó
openchamber serve --port 8081 ${OPENCHAMBER_UI_PASSWORD:+--ui-password "$OPENCHAMBER_UI_PASSWORD"}

echo "OpenChamber is running in background on internal port 8081."

# Socat giữ cổng APP_PORT (8080) luôn mở cho Hugging Face
# Chuyển tiếp lưu lượng từ APP_PORT vào cổng thực tế 8081
echo "Socat bridge active: ${APP_PORT} -> 8081"
exec socat TCP-LISTEN:${APP_PORT},fork,reuseaddr TCP:127.0.0.1:8081
EOF

RUN chmod +x /usr/local/bin/entrypoint

# 5. Cấu hình vận hành
EXPOSE 8080
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/entrypoint"]
