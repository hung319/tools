# syntax=docker/dockerfile:1
FROM debian:stable-slim

USER root

# Thiết lập biến môi trường toàn cục
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    UV_SYSTEM_PYTHON=1

# 1. Cài đặt dependencies và System Python (Debian Stable hiện là Python 3.13)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates procps git sudo python3 python3-pip \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# 2. Lấy uv siêu tốc và tải Cloudflared binary
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
ADD --chmod=755 https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 /usr/local/bin/cloudflared

WORKDIR /app

# 3. Bypass PEP 668 cho pip thuần (Đảm bảo gõ `pip install` trong Jupyter không bị lỗi)
RUN python3 -m pip config set global.break-system-packages true

# 4. Cài đặt JupyterLab qua uv (Bypass PEP 668 lúc build)
RUN uv pip install --system --break-system-packages --no-cache jupyterlab

# 5. Entrypoint Script (Xử lý Auth & Khởi chạy dịch vụ)
COPY --chmod=755 <<"EOF" /entrypoint.sh
#!/bin/bash
set -e

if [ -n "$CF_TUNNEL_TOKEN" ]; then
  echo "[INFO] Starting Cloudflared tunnel..."
  cloudflared tunnel --no-autoupdate run --token "$CF_TUNNEL_TOKEN" &
fi

if [ -n "$REMOTE_KEY" ]; then
  echo "[INFO] Generating Jupyter password hash..."
  # Tự động băm mật khẩu từ biến môi trường REMOTE_KEY sang mã hóa Argon2
  HASHED_PW=$(python3 -c "from jupyter_server.auth.security import passwd; import os; print(passwd(os.environ.get('REMOTE_KEY', '')))")

  echo "[INFO] Starting JupyterLab (System Env + Iframe Optimized)..."
  exec jupyter lab --ip=0.0.0.0 --port=7860 --no-browser --allow-root \
    --ServerApp.password="$HASHED_PW" \
    --IdentityProvider.token="" \
    --ServerApp.base_url="/" \
    --ServerApp.terminado_settings="{'shell_command': ['/bin/bash']}" \
    --ServerApp.allow_origin="*" \
    --ServerApp.trust_xheaders=True \
    --ServerApp.disable_check_xsrf=True \
    --ServerApp.tornado_settings="{'headers': {'Content-Security-Policy': \"frame-ancestors * 'self'\"}}"
else
  echo "⚠️ [ERROR] Vui lòng đặt REMOTE_KEY (Password) trong Secrets!"
  exit 1
fi
EOF

EXPOSE 7860
ENTRYPOINT ["/entrypoint.sh"]
