# ==========================================
# 1. SOURCE-FETCHER: Tải và Patch code
# ==========================================
FROM debian:bookworm-slim AS source-fetcher
RUN apt-get update && apt-get install -y curl tar sed ca-certificates

WORKDIR /src
RUN LATEST_URL=$(curl -s https://api.github.com/repos/chriswritescode-dev/opencode-manager/releases/latest | grep "tarball_url" | cut -d '"' -f 4) \
    && curl -Ls "$LATEST_URL" | tar -xzf - --strip-components=1

# Patch script gốc để tương thích với quyền root
RUN if [ -f scripts/docker-entrypoint.sh ]; then \
        sed -i 's/export HOME=\/home\/node/export HOME=\/root/g' scripts/docker-entrypoint.sh && \
        sed -i 's/\/home\/node/\/root/g' scripts/docker-entrypoint.sh && \
        sed -i 's/chown -R node:node.*/# Root mode/g' scripts/docker-entrypoint.sh && \
        sed -i 's/exec runuser -u node -- "$@"/exec "$@"/g' scripts/docker-entrypoint.sh; \
    fi

# ==========================================
# 2. BUILDER: Build ứng dụng
# ==========================================
FROM node:24.13.0-slim AS builder
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /root
COPY --from=source-fetcher /src .
RUN pnpm install --frozen-lockfile && \
    pnpm --filter frontend build && \
    CI=true pnpm install --prod --frozen-lockfile

# ==========================================
# 3. RUNNER: Image cuối cùng tích hợp Auto-Backup
# ==========================================
FROM node:24.13.0-slim AS runner

# Cài đặt system packages (Thêm inotify-tools, zip, unzip cho backup)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl lsof ripgrep ca-certificates grep gawk sed findutils \
    coreutils procps jq less tree file python3 python3-pip python3-venv \
    unzip zip inotify-tools tini chromium bash \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Cài đặt Bun & Opencode Tools
RUN curl -fsSL https://bun.sh/install | bash && ln -s /root/.bun/bin/bun /usr/local/bin/bun
RUN curl -fsSL https://opencode.ai/install | bash -s -- --no-modify-path && \
    mv /root/.opencode /opt/opencode && ln -s /opt/opencode/bin/opencode /usr/local/bin/opencode

WORKDIR /root

# Copy sản phẩm từ giai đoạn build
COPY --from=builder /root/node_modules ./node_modules
COPY --from=builder /root/shared ./shared
COPY --from=builder /root/backend ./backend
COPY --from=builder /root/frontend/dist ./frontend/dist
COPY --from=source-fetcher /src/package.json /src/pnpm-workspace.yaml ./

# --- BIẾN MÔI TRƯỜNG ---
ENV NODE_ENV=production \
    HOST=0.0.0.0 \
    PORT=5003 \
    HOME=/root \
    # Biến mới yêu cầu
    AUTH_SECRET="super-secret-key-change-me" \
    # Cấu hình Backup
    BACKUP_DIR="/data" \
    BACKUP_FILENAME="opencode_backup.zip" \
    BACKUP_PASS="123456" \
    DATABASE_PATH=/root/data/opencode.db \
    WORKSPACE_PATH=/root/workspace

# Tạo thư mục cần thiết
RUN mkdir -p /root/data /root/workspace /root/.cache /data && chmod -R 777 /root /data

# --- TẠO ENTRYPOINT SCRIPT TÍCH HỢP BACKUP ---
RUN cat <<'EOF' > /usr/local/bin/entrypoint.sh && chmod +x /usr/local/bin/entrypoint.sh
#!/bin/bash
set -e

restore_data() {
    if [ -f "$BACKUP_DIR/$BACKUP_FILENAME" ]; then
        echo "--- [RESTORE] Tìm thấy bản lưu. Đang phục hồi dữ liệu... ---"
        unzip -oP "$BACKUP_PASS" "$BACKUP_DIR/$BACKUP_FILENAME" -d / > /dev/null 2>&1 || true
        echo "--- [RESTORE] Phục hồi thành công! ---"
    fi
}

backup_data() {
    echo "--- [BACKUP] Đang sao lưu dữ liệu vào $BACKUP_DIR... ---"
    mkdir -p "$BACKUP_DIR"
    # Nén /root nhưng loại bỏ các thư mục rác/cache để giảm dung lượng
    zip -qrP "$BACKUP_PASS" "/tmp/temp_backup.zip" /root \
        -x "/root/.cache/*" "/root/.npm/*" "/root/.bun/*" "/root/node_modules/*" "*.log" 2>/dev/null || true
    
    if [ -f "/tmp/temp_backup.zip" ]; then
        mv "/tmp/temp_backup.zip" "$BACKUP_DIR/$BACKUP_FILENAME"
        echo "--- [BACKUP] Đã cập nhật bản sao lưu lúc $(date) ---"
    fi
}

cleanup() {
    echo "!!! [STOP] Đang thực hiện sao lưu cuối cùng... !!!"
    backup_data
    exit 0
}

trap cleanup SIGTERM SIGINT

# 1. Phục hồi dữ liệu trước khi chạy
restore_data

# 2. Chạy watcher sao lưu ngầm (mỗi khi có thay đổi file sau 60s)
(
    while true; do
        inotifywait -r -e modify,create,delete,move -t 60 \
            --excludei '(/\.cache|/\.npm|/\.bun|/node_modules/|\.log$)' /root/data /root/workspace 2>/dev/null || true
        sleep 10
        backup_data
    done
) &

# 3. Khởi động ứng dụng chính
echo "Đang khởi động Opencode Manager trên cổng $PORT..."
exec bun backend/src/index.ts
EOF

EXPOSE 5003

# Sử dụng tini để quản lý zombie process và signal tốt hơn
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/entrypoint.sh"]
